// PulseTrack — Prisma schema (Phase 1 core).
// Source of truth for the data model: Progress_Tracking_App_Plan.md (§2–§5, §9)
// and CLAUDE.md "Domain rules". Marketing models (SEO/Social/Content/Kanban/
// editorial calendar) are added in Phase 3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  MEMBER // own data only
  TEAM_LEAD // whole department
  SUB_DEPT_LEAD // one Marketing sub-department
  QA // quality-assurance evaluator (scores ITAD/CSR agents)
  QA_LEAD // manages the QA team (all QA powers + QA-team oversight)
  SUPER_ADMIN // everything
}

/// Account approval state. Team Leads self-register as PENDING and must be
/// approved by a Super Admin before they can log in. Everyone else is ACTIVE.
enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

/// Kinds of team-roster changes recorded for the Team History view.
enum TeamEventType {
  INVITED
  REMOVED
  REACTIVATED
}

enum DepartmentType {
  ITAD
  LEAD_GEN
  MARKETING
  CSR
  ECOMMERCE
}

/// Status of a daily entry. A non-SUBMITTED day carries no metrics and is
/// excluded from averages/targets (leave-aware rule).
enum DayStatus {
  SUBMITTED
  ON_LEAVE
  HOLIDAY
  OFF
}

enum TagType {
  VERTICAL // Lead Gen industry verticals (School District, Telecom, ...)
  LEAD_TYPE // Lead Gen lead categories (New Lead, BBR, RTLG)
  PLATFORM // Social platforms (Facebook, LinkedIn, ...)
  CAMPAIGN
  DATA_SOURCE
  MARKETPLACE // Ecommerce marketplaces (Amazon, eBay, Walmart, Newegg)
  TASK_TYPE // Ecommerce listing task types (BTO, Kits, Pricing, ...)
}

enum TargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum TargetScope {
  DEPARTMENT
  SUB_DEPARTMENT
  USER
  BRAND // a Marketing brand/profile target (e.g. monthly followers goal)
}

enum LeaveType {
  ON_LEAVE
  HOLIDAY
  OFF
  WFH // Working from home — a worked day: person can still clock in (off-network allowed) and metrics count.
}

/// Tone of a piece of Team Lead → employee feedback.
enum FeedbackSentiment {
  PRAISE
  NEUTRAL
  IMPROVEMENT
}

// ---------- Org structure ----------

model Department {
  id        String         @id @default(cuid())
  type      DepartmentType @unique
  name      String
  createdAt DateTime       @default(now())

  subDepartments  SubDepartment[]
  users           User[]
  tags            Tag[]
  targets         Target[]
  feedback        Feedback[]
  qaEvaluations   QaEvaluation[]
  stockRequests   StockRequest[]
  attendanceShift AttendanceShift?
  meetingNotes    MeetingNote[]
  bids            Bid[]
  brands          Brand[]
  marketingPlans  MarketingPlan[]
}

model SubDepartment {
  id           String     @id @default(cuid())
  name         String
  slug         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())

  users          User[]
  targets        Target[]
  marketingPlans MarketingPlan[]

  @@unique([departmentId, slug])
}

// ---------- Users & auth ----------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String? // null for SSO-only accounts
  tempPassword String? // last issued temp credential, visible to the Team Lead until the member changes their own password
  googleId     String?    @unique
  name         String
  role         Role       @default(MEMBER)
  status       UserStatus @default(ACTIVE)
  isActive     Boolean    @default(true)
  // Sessions (JWTs) issued before this instant are rejected — bumped on disable,
  // password change, and admin password reset to revoke existing tokens.
  sessionsValidFrom DateTime?

  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  subDepartmentId String?
  subDepartment   SubDepartment? @relation(fields: [subDepartmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itadEntries     ItadDailyEntry[]
  leadGenEntries  LeadGenDailyEntry[]
  seoEntries      SeoDailyEntry[]
  socialEntries   SocialDailyEntry[]
  marketingTasks  MarketingTask[]
  leaveDays       LeaveDay[]
  attendanceDays  AttendanceDay[]
  attendanceShift AttendanceShift?    @relation("UserShift")
  targets         Target[]            @relation("UserTargets")
  setTargets      Target[]            @relation("TargetSetBy")
  auditLogs       AuditLog[]

  feedbackAuthored Feedback[]      @relation("FeedbackAuthored")
  feedbackReceived Feedback[]      @relation("FeedbackReceived")
  feedbackReplies  FeedbackReply[] @relation("FeedbackReplies")

  qaAuthored   QaEvaluation[] @relation("QaAuthored")
  qaReceived   QaEvaluation[] @relation("QaReceived")
  qaScorecards QaScorecard[]

  attachments EntryAttachment[]

  ecommerceEntries  EcommerceDailyEntry[]
  ecomTasksAssigned EcommerceTask[]       @relation("EcomTaskAssignee")
  ecomTasksCreated  EcommerceTask[]       @relation("EcomTaskCreator")
  ecomTaskComments  EcomTaskComment[]     @relation("EcomCommentAuthor")
  marketingTaskComments MarketingTaskComment[] @relation("MarketingCommentAuthor")
  notifications      Notification[] @relation("NotificationRecipient")
  notificationsActed Notification[] @relation("NotificationActor")
  stockAssignedTo   StockRequest[]        @relation("StockAssignee")
  stockAssignedBy   StockRequest[]        @relation("StockAssigner")

  todos               TodoItem[]
  meetingNotes        MeetingNote[]        @relation("MeetingNoteAuthor")
  bids                Bid[]                @relation("BidAgent")
  attendanceReminders AttendanceReminder[]

  brandSocialEntries    BrandSocialMonthly[] @relation("BrandSocialEnteredBy")
  blogPosts             BlogPost[]           @relation("BlogAuthor")
  marketingPlansCreated MarketingPlan[]      @relation("MarketingPlanCreatedBy")
  planItemsOwned        MarketingPlanItem[]  @relation("PlanItemOwner")

  @@index([departmentId])
  @@index([subDepartmentId])
}

// ---------- Daily-log file attachments (ITAD / Lead Gen) ----------

enum AttachmentKind {
  ITAD
  LEAD_GEN
  QA_RECORDING
}

/// A file an employee attaches to their daily log (Excel, Word, PDF, ...).
/// Linked by user + kind + date so it survives entry re-submission.
model EntryAttachment {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         AttachmentKind
  date         DateTime       @db.Date
  storedName   String // randomized filename on disk
  originalName String // name shown to the user
  mimeType     String
  size         Int
  createdAt    DateTime       @default(now())

  qaEvaluation QaEvaluation? // set when this attachment is a QA call recording

  @@index([userId, kind, date])
}

// ---------- ITAD daily entries (§4.1) ----------

model ItadDailyEntry {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime  @db.Date
  status DayStatus @default(SUBMITTED)

  callsDialed Int @default(0)
  connected   Int @default(0)
  voicemail   Int @default(0)
  emailsSent  Int @default(0)
  interested  Int @default(0)
  workingOn   Int @default(0)
  closed      Int @default(0)
  rfqs        Int @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One entry per user per day — re-submitting upserts, never duplicates.
  @@unique([userId, date])
  @@index([date])
}

// ---------- Lead Gen daily entries (§5.1) ----------

model LeadGenDailyEntry {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime  @db.Date
  status DayStatus @default(SUBMITTED)

  leadsGenerated     Int @default(0)
  accountsResearched Int @default(0)
  contactsFound      Int @default(0)
  qualifiedMql       Int @default(0)
  handedToSql        Int @default(0)

  dataSource String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  verticalCounts LeadGenVerticalCount[]

  @@unique([userId, date])
  @@index([date])
}

/// Leads-per-vertical breakdown for a Lead Gen entry (§5.1).
model LeadGenVerticalCount {
  id      String            @id @default(cuid())
  entryId String
  entry   LeadGenDailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag               @relation(fields: [tagId], references: [id])
  count   Int               @default(0)

  @@unique([entryId, tagId])
}

// ---------- Team roster history (Team Lead invites / removals) ----------

/// An append-only log of team membership changes, scoped to a department.
/// Member name/email are snapshotted so history reads correctly over time.
model TeamMemberEvent {
  id           String        @id @default(cuid())
  departmentId String
  actorId      String? // who performed the action (Team Lead / Admin)
  actorName    String
  memberId     String? // affected member
  memberName   String
  memberEmail  String
  type         TeamEventType
  createdAt    DateTime      @default(now())

  @@index([departmentId, createdAt])
}

// ---------- Tags (TL-managed lists: verticals, platforms, ...) ----------

model Tag {
  id           String      @id @default(cuid())
  name         String
  type         TagType
  group        String? // for Ecommerce TASK_TYPE fields: the parent Type (Listings, Pricing, ...)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())

  verticalCounts LeadGenVerticalCount[]
  socialCounts   SocialPlatformCount[]

  ecomTaskLines        EcommerceListingLine[] @relation("LineTaskType")
  ecomMarketplaceLines EcommerceListingLine[] @relation("LineMarketplace")

  @@unique([departmentId, type, name])
}

// ---------- Targets (§3) ----------

model Target {
  id        String       @id @default(cuid())
  scope     TargetScope
  metricKey String // e.g. "callsDialed", "leadsGenerated", "connectRate"
  period    TargetPeriod
  value     Float // kept as the headline goal (= maxValue) for status/trend references
  minValue  Float? // acceptable lower bound of the target range
  maxValue  Float? // goal / upper bound of the target range

  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  subDepartmentId String?
  subDepartment   SubDepartment? @relation(fields: [subDepartmentId], references: [id])
  userId          String?
  user            User?          @relation("UserTargets", fields: [userId], references: [id])
  brandId         String?
  brand           Brand?         @relation(fields: [brandId], references: [id])

  setById       String?
  setBy         User?    @relation("TargetSetBy", fields: [setById], references: [id])
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([departmentId, metricKey])
  @@index([userId, metricKey])
  @@index([brandId, metricKey])
}

// ---------- Leave / holidays (§3, leave-aware rule) ----------

/// Company-wide non-working days.
model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  name      String
  createdAt DateTime @default(now())
}

/// Per-user leave/off days (set by user or admin). Excluded from averages.
model LeaveDay {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  type      LeaveType @default(ON_LEAVE)
  note      String?
  createdAt DateTime  @default(now())

  @@unique([userId, date])
  @@index([date])
}

// ---------- Time & attendance (check-in / check-out / breaks) ----------

/// One attendance record per user per day. Check-in/out are full instants;
/// the `date` is the company-day bucket (companyToday). Worked/break minutes are
/// computed on read from these + the breaks, never stored.
model AttendanceDay {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime  @db.Date
  checkInAt  DateTime?
  checkOutAt DateTime?
  checkInIp  String? // client IP recorded at check-in (audit / office-network enforcement)
  checkOutIp String?
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  breaks BreakEntry[]

  @@unique([userId, date])
  @@index([date])
}

/// Admin-managed allowlist of office networks. A check-in/out is accepted only
/// from an IP inside one of these (unless the list is empty, or the caller is a
/// Super Admin). `cidr` accepts a bare IP (treated as /32) or CIDR range.
model OfficeNetwork {
  id        String   @id @default(cuid())
  label     String
  cidr      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum ReminderKind {
  CHECK_IN
  CHECK_OUT
}

/// One row per (user, day, kind) once a reminder email has been sent — the
/// scheduler uses it to avoid sending duplicate check-in/out reminders.
model AttendanceReminder {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime     @db.Date
  kind   ReminderKind
  sentAt DateTime     @default(now())

  @@unique([userId, date, kind])
  @@index([date])
}

/// A single break within an attendance day. `endAt` null = break still open.
model BreakEntry {
  id        String        @id @default(cuid())
  dayId     String
  day       AttendanceDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime?
  createdAt DateTime      @default(now())

  @@index([dayId])
}

/// Expected working hours that drive the late / early-leave / shift-completion
/// flags. Resolution order per employee: user override → department → company.
/// A row is one of: company default (both ids null), a department row
/// (departmentId set), or a per-account override (userId set).
model AttendanceShift {
  id              String      @id @default(cuid())
  departmentId    String?     @unique
  department      Department? @relation(fields: [departmentId], references: [id])
  userId          String?     @unique
  user            User?       @relation("UserShift", fields: [userId], references: [id], onDelete: Cascade)
  startTime       String // "HH:mm" in the shift's timezone, e.g. "09:00"
  endTime         String // "HH:mm", e.g. "18:00". If <= startTime the shift crosses midnight (overnight).
  graceMin        Int         @default(10)
  requiredMinutes Int         @default(480) // full-shift target; worked >= this = shift completed
  workingDays     Int[]       @default([1, 2, 3, 4, 5]) // 0=Sun … 6=Sat; which weekdays are worked
  timeZone        String? // IANA tz (e.g. "America/New_York"); null = company timezone
  updatedAt       DateTime    @updatedAt
}

// ---------- RDP inventory & assignment history (Ecommerce/CSR/Shipping) ----------

/// Which team an RDP belongs to (tabs in the source spreadsheet).
enum RdpTeam {
  EC
  CSR
  SHIPPING
}

/// A remote machine identified by provider + address (an IP or an Anydesk ID).
/// One RDP can be used by several agents; usage over time lives in assignments.
model Rdp {
  id        String   @id @default(cuid())
  team      RdpTeam
  provider  String // Sj Computers, MaxE Computers, Anydesk, ...
  address   String // IP address or Anydesk ID (free text)
  label     String?
  notes     String?
  active    Boolean  @default(true) // false = retired
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments RdpAssignment[]

  @@unique([provider, address])
  @@index([team])
}

/// A period an agent used an RDP. `unassignedAt` null = currently assigned.
/// Agent is stored by name (snapshot) so history survives staff changes.
model RdpAssignment {
  id           String    @id @default(cuid())
  rdpId        String
  rdp          Rdp       @relation(fields: [rdpId], references: [id], onDelete: Cascade)
  agentName    String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  note         String?
  createdAt    DateTime  @default(now())

  @@index([rdpId])
  @@index([agentName])
}

// ---------- Audit trail (§9) ----------

/// Edit history so submitted numbers cannot be quietly changed.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String // "ItadDailyEntry", "Target", ...
  entityId   String
  action     String // "CREATE" | "UPDATE" | "DELETE"
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// ========== Marketing (Phase 3) — §6 ==========

enum MarketingDiscipline {
  SEO
  SOCIAL
  CONTENT
}

/// Kanban / editorial pipeline stages (§6.4).
enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  SCHEDULED
  PUBLISHED
}

enum ContentType {
  BLOG
  LANDING_PAGE
  SOCIAL_COPY
  VIDEO_SCRIPT
  EMAIL
  OTHER
}

// ---------- SEO daily activity (§6.1) ----------
model SeoDailyEntry {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime  @db.Date
  status DayStatus @default(SUBMITTED)

  keywordsTracked Int @default(0)
  pagesOptimized  Int @default(0)
  backlinksBuilt  Int @default(0)
  technicalFixes  Int @default(0)
  organicTraffic  Int @default(0) // manually entered key figure (GSC/GA4 integration later)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
}

// ---------- Social daily activity (§6.2) ----------
model SocialDailyEntry {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime  @db.Date
  status DayStatus @default(SUBMITTED)

  postsPublished  Int @default(0)
  postsScheduled  Int @default(0)
  reach           Int @default(0)
  engagement      Int @default(0)
  followersGained Int @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platformCounts SocialPlatformCount[]

  @@unique([userId, date])
  @@index([date])
}

/// Posts-per-platform breakdown for a social entry.
model SocialPlatformCount {
  id      String           @id @default(cuid())
  entryId String
  entry   SocialDailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag              @relation(fields: [tagId], references: [id])
  posts   Int              @default(0)

  @@unique([entryId, tagId])
}

// ---------- Marketing tasks: Kanban board + editorial calendar + content (§6.3/§6.4) ----------
model MarketingTask {
  id          String              @id @default(cuid())
  title       String
  description String?
  discipline  MarketingDiscipline
  status      TaskStatus          @default(BACKLOG)
  order       Int                 @default(0) // position within its column

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id])

  // Optional brand/profile a content card targets (drives board brand filter + blog origin)
  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  // Content-specific (when discipline = CONTENT)
  contentType ContentType?
  wordCount   Int?
  wordTarget  Int?

  // Editorial calendar — planned vs actual
  dueDate       DateTime? @db.Date
  scheduledDate DateTime? @db.Date
  publishedDate DateTime? @db.Date
  completedAt   DateTime? // set when the task reaches PUBLISHED; powers "completed by day/week"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments MarketingTaskComment[]

  @@index([status])
  @@index([discipline])
  @@index([scheduledDate])
  @@index([assigneeId])
}

/// Once-only claim so the scheduled monthly report emails each (month, department)
/// exactly once, even across restarts or multiple cron ticks on the 1st–2nd.
model SentMonthlyReport {
  id         String   @id @default(cuid())
  month      String // 'YYYY-MM'
  department String
  sentAt     DateTime @default(now())

  @@unique([month, department])
}

enum NotificationType {
  MENTION
}

/// A delivered, per-recipient notification (e.g. an @mention on a board card).
/// Read state is per row; the bell shows unread ones and marks them read on click.
model Notification {
  id         String           @id @default(cuid())
  userId     String // recipient
  user       User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType @default(MENTION)
  actorId    String? // who triggered it
  actor      User?            @relation("NotificationActor", fields: [actorId], references: [id])
  title      String
  body       String
  link       String? // client route to open when clicked
  entityType String? // e.g. "MarketingTask"
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
}

model MarketingTaskComment {
  id        String        @id @default(cuid())
  taskId    String
  task      MarketingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("MarketingCommentAuthor", fields: [authorId], references: [id])
  body      String
  mentions  String[] // user ids @mentioned in the body
  createdAt DateTime      @default(now())

  @@index([taskId])
}

// ---------- Marketing brands / profiles + monthly reporting (§6) ----------

/// A company profile / brand the Marketing team manages (e.g. Minnesota
/// Computers, Recycle Technologies). The spine that ties monthly social stats,
/// blog counts and master-plan items together. User-manageable (add/edit).
model Brand {
  id           String     @id @default(cuid())
  departmentId String // always the MARKETING department
  department   Department @relation(fields: [departmentId], references: [id])
  name         String
  slug         String
  website      String?
  isActive     Boolean    @default(true) // soft-delete; preserves historical stats
  // SEO integration — a brand is "connected" once both are set.
  gscSiteUrl    String? // Search Console property, e.g. "sc-domain:example.com" or "https://example.com/"
  ga4PropertyId String? // GA4 property, e.g. "properties/123456789" (or the bare numeric id)
  seoSyncedAt   DateTime? // last successful GSC/GA sync
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  socialStats BrandSocialMonthly[]
  seoDaily    BrandSeoDaily[]
  blogs       BlogPost[]
  tasks       MarketingTask[]
  planItems   MarketingPlanItem[]
  targets     Target[]

  @@unique([departmentId, slug])
  @@index([departmentId, isActive])
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  X
  TIKTOK
  YOUTUBE
  GOOGLE_BUSINESS
  OTHER
}

/// Source of a monthly stat row — manual entry now, platform-API sync later.
enum StatSource {
  MANUAL
  API
}

/// One monthly snapshot per brand + platform. `followers` is a total snapshot;
/// month-over-month growth is derived. Upsert key = (brandId, platform, month).
model BrandSocialMonthly {
  id       String         @id @default(cuid())
  brandId  String
  brand    Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  platform SocialPlatform
  month    String // "YYYY-MM"

  followers   Int @default(0) // total followers at month end
  impressions Int @default(0)
  engagement  Int @default(0)
  reach       Int @default(0)
  posts       Int @default(0)

  // Extended metrics from LinkedIn Analytics / Meta Business Suite exports.
  newFollowers   Int   @default(0) // followers gained in the month
  visitors       Int   @default(0) // unique page visitors
  engagementRate Float @default(0) // avg engagement rate as a percentage, e.g. 21.4
  clicks         Int   @default(0)
  reactions      Int   @default(0) // likes + reactions
  views          Int   @default(0) // post/video views

  source      StatSource @default(MANUAL)
  enteredById String?
  enteredBy   User?      @relation("BrandSocialEnteredBy", fields: [enteredById], references: [id])
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([brandId, platform, month])
  @@index([brandId, month])
  @@index([month])
}

/// One day of SEO metrics per brand, pulled from Google Search Console (GSC) and
/// Google Analytics (GA4). Stored daily so day/week/month rollups derive on read.
/// Upsert key = (brandId, date). CTR and position are averages, not sums —
/// aggregate them impressions-weighted, never added.
model BrandSeoDaily {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date

  // Google Search Console
  clicks      Int   @default(0)
  impressions Int   @default(0)
  ctr         Float @default(0) // click-through rate, 0..1 (as GSC returns it)
  position    Float @default(0) // average position (lower is better)

  // Google Analytics (GA4)
  sessions        Int   @default(0)
  users           Int   @default(0) // activeUsers
  newUsers        Int   @default(0)
  engagedSessions Int   @default(0)
  conversions     Int   @default(0)
  bounceRate      Float @default(0) // 0..1

  source    StatSource @default(API)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([brandId, date])
  @@index([brandId, date])
}

/// A blog/article attributed to a brand, for month-end per-brand counts.
model BlogPost {
  id          String    @id @default(cuid())
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id])
  title       String
  url         String?
  wordCount   Int?
  authorId    String?
  author      User?     @relation("BlogAuthor", fields: [authorId], references: [id])
  publishedAt DateTime? @db.Date
  month       String // "YYYY-MM" the blog counts toward (denormalized for fast counts)
  taskId      String? // optional link to the originating MarketingTask card
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([brandId, month])
  @@index([month])
}

/// The content lead's monthly Master Plan — a month-scoped container of items.
model MarketingPlan {
  id              String         @id @default(cuid())
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id])
  subDepartmentId String? // usually the "content" sub-dept; null = whole-Marketing plan
  subDepartment   SubDepartment? @relation(fields: [subDepartmentId], references: [id])
  month           String // "YYYY-MM"
  title           String?
  createdById     String?
  createdBy       User?          @relation("MarketingPlanCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items MarketingPlanItem[]

  @@unique([departmentId, subDepartmentId, month])
  @@index([month])
}

enum PlanItemStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  PENDING
}

/// A single Master Plan task. Fields mirror the "MONTHLY TASKS" reference sheet.
model MarketingPlanItem {
  id     String        @id @default(cuid())
  planId String
  plan   MarketingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  title       String // TASK TITLE
  taskType    String? // TASK TYPE (Strategy & Planning, Website Content, Social Media, …)
  brandId     String? // PROJECT (null renders as "General")
  brand       Brand?         @relation(fields: [brandId], references: [id])
  ownerId     String? // STAKEHOLDER, when a system user
  owner       User?          @relation("PlanItemOwner", fields: [ownerId], references: [id])
  stakeholder String? // free-text stakeholder fallback (non-users)
  status      PlanItemStatus @default(PLANNED)

  plannedDate    DateTime? @db.Date // PLANNED DATE
  completionDate DateTime? @db.Date // COMPLETION DATE
  documentLink   String? // DOCUMENT LINK

  order     Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId, order])
}

// ========== Feedback & reviews (TL ↔ employee) ==========

/// A Team Lead's feedback to an employee. Two-way: the thread carries replies
/// from either participant. Per-participant read timestamps drive the unread
/// bell + dashboard badge (latest activity newer than your read = unread).
model Feedback {
  id           String      @id @default(cuid())
  authorId     String
  author       User        @relation("FeedbackAuthored", fields: [authorId], references: [id])
  recipientId  String
  recipient    User        @relation("FeedbackReceived", fields: [recipientId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  title     String?
  body      String
  sentiment FeedbackSentiment @default(NEUTRAL)

  recipientReadAt DateTime?
  authorReadAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies FeedbackReply[]

  @@index([recipientId])
  @@index([authorId])
}

/// A reply within a feedback thread, from either participant.
model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("FeedbackReplies", fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())

  @@index([feedbackId])
}

// ========== Quality Assurance (call-quality evaluations) ==========

enum QaQuestionType {
  RATING // scored 0..maxScore (default 10)
  YES_NO // Yes = full marks, No = 0
}

enum QaEvaluationStatus {
  DRAFT
  SUBMITTED
}

/// A configurable scorecard template: weighted categories of questions.
model QaScorecard {
  id             String          @id @default(cuid())
  name           String
  description    String?
  departmentType DepartmentType? // null = applies to any department
  passThreshold  Float           @default(50) // "Acceptable" line; below this = Unacceptable
  bandGood       Float           @default(64) // >= this = "A good result"
  bandExcellent  Float           @default(82) // >= this = "Excellent"
  isActive       Boolean         @default(true)
  createdById    String?
  createdBy      User?           @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  categories  QaCategory[]
  evaluations QaEvaluation[]
}

model QaCategory {
  id          String      @id @default(cuid())
  scorecardId String
  scorecard   QaScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  name        String
  weight      Float       @default(0) // flat-points model: sections are headings (weight unused)
  order       Int         @default(0)

  questions QaQuestion[]

  @@index([scorecardId])
}

model QaQuestion {
  id           String         @id @default(cuid())
  categoryId   String
  category     QaCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  text         String
  type         QaQuestionType @default(RATING)
  maxScore     Int            @default(10)
  criticalFail Boolean        @default(false)
  allowNA      Boolean        @default(true)
  order        Int            @default(0)

  @@index([categoryId])
}

/// A completed evaluation of an agent. Stores SNAPSHOTS of the scorecard so
/// later template edits never change historical scores.
model QaEvaluation {
  id            String       @id @default(cuid())
  scorecardId   String?
  scorecard     QaScorecard? @relation(fields: [scorecardId], references: [id])
  scorecardName String
  evaluatorId   String
  evaluator     User         @relation("QaAuthored", fields: [evaluatorId], references: [id])
  agentId       String
  agent         User         @relation("QaReceived", fields: [agentId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])

  callReference         String?
  customerNumber        String?
  callDate              DateTime?
  recordingAttachmentId String?          @unique
  recording             EntryAttachment? @relation(fields: [recordingAttachmentId], references: [id])

  status                QaEvaluationStatus @default(SUBMITTED)
  totalScore            Float              @default(0) // 0..100
  band                  String             @default("Unacceptable") // Unacceptable | Acceptable | Good | Excellent
  passed                Boolean            @default(false)
  criticalFailTriggered Boolean            @default(false)
  coachingNeeded        Boolean            @default(false)
  overallComments       String?

  agentReadAt         DateTime?
  agentAcknowledgedAt DateTime?
  agentRebuttal       String?

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categories QaEvaluationCategory[]
  answers    QaAnswer[]

  @@index([agentId])
  @@index([evaluatorId])
  @@index([departmentId, createdAt])
}

/// Per-category snapshot of a completed evaluation (powers category analytics).
model QaEvaluationCategory {
  id           String       @id @default(cuid())
  evaluationId String
  evaluation   QaEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  name         String
  weight       Float        @default(0)
  earned       Float        @default(0) // points earned in this section
  maxPossible  Float        @default(0) // points available (excludes N/A)
  scorePct     Float // 0..100
  comment      String?
  order        Int          @default(0)

  @@index([evaluationId])
}

/// Per-question snapshot of a completed evaluation (powers the detail view).
model QaAnswer {
  id           String         @id @default(cuid())
  evaluationId String
  evaluation   QaEvaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  categoryName String
  questionText String
  type         QaQuestionType
  maxScore     Int            @default(10)
  criticalFail Boolean        @default(false)
  score        Int? // null when isNA
  isNA         Boolean        @default(false)
  order        Int            @default(0)

  @@index([evaluationId])
}

/// Kind of a Lead Gen monthly breakdown row.
enum BreakdownKind {
  CAMPAIGN
  INDUSTRY
}

/// Month-level Lead Gen breakdown by campaign (BBR, RTLG, …) and industry
/// (IT Services, Health Care, …). Maintained by TL/Admin; powers the Team View
/// summary cards. One row per (month, category); month is "YYYY-MM".
model LeadGenBreakdown {
  id        String        @id @default(cuid())
  month     String // "YYYY-MM"
  category  String
  kind      BreakdownKind @default(INDUSTRY)
  count     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([month, category])
  @@index([month])
}

// ============================ Ecommerce department ============================

enum EcomTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum StockStatus {
  REQUESTED
  ASSIGNED
  RESOLVED
}

enum StockAction {
  STOCK_IN
  STOCK_OUT
}

/// One Ecommerce daily report per user per day; listing counts live in the lines.
model EcommerceDailyEntry {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime  @db.Date
  status       DayStatus @default(SUBMITTED)
  notes        String?
  pricingNotes String? // free-text Pricing work (replaces the numeric pricing grid)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines EcommerceListingLine[]

  @@unique([userId, date])
  @@index([date])
}

/// A single (task type × marketplace × #listings) line on a daily report.
model EcommerceListingLine {
  id            String              @id @default(cuid())
  entryId       String
  entry         EcommerceDailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  taskTypeId    String
  taskType      Tag                 @relation("LineTaskType", fields: [taskTypeId], references: [id])
  marketplaceId String
  marketplace   Tag                 @relation("LineMarketplace", fields: [marketplaceId], references: [id])
  listings      Int                 @default(0)

  @@index([entryId])
}

/// Shared Ecommerce task board (Kanban). HOD assigns; the whole team sees all.
model EcommerceTask {
  id           String         @id @default(cuid())
  title        String
  description  String?
  source       String? // free-text "from" — who/where the task came from
  status       EcomTaskStatus @default(TODO)
  order        Int            @default(0)
  assignedToId String?
  assignedTo   User?          @relation("EcomTaskAssignee", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?          @relation("EcomTaskCreator", fields: [createdById], references: [id])
  dueDate      DateTime?      @db.Date
  completedAt  DateTime? // set when the task reaches DONE; powers "completed by day/week"
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  comments EcomTaskComment[]

  @@index([status])
  @@index([assignedToId])
}

/// A comment on an Ecommerce task (Jira/Trello-style thread). `mentions` holds the
/// mentioned users' ids so they can be highlighted (and later notified).
model EcomTaskComment {
  id        String        @id @default(cuid())
  taskId    String
  task      EcommerceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("EcomCommentAuthor", fields: [authorId], references: [id])
  body      String
  mentions  String[]
  createdAt DateTime      @default(now())

  @@index([taskId])
}

/// Out-of-stock request → HOD assigns a stock-in/out action to an agent.
model StockRequest {
  id              String      @id @default(cuid())
  departmentId    String
  department      Department  @relation(fields: [departmentId], references: [id])
  itemName        String
  requestedByName String // free text — operations person (outside the app)
  note            String?
  requestedAt     DateTime    @default(now())
  status          StockStatus @default(REQUESTED)

  action       StockAction?
  assignedToId String?
  assignedTo   User?        @relation("StockAssignee", fields: [assignedToId], references: [id])
  assignedById String?
  assignedBy   User?        @relation("StockAssigner", fields: [assignedById], references: [id])
  assignedAt   DateTime?
  resolvedAt   DateTime?

  @@index([departmentId, status])
}

// Personal, private to-do list — one owner, not shared. Every user gets one.
model TodoItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean   @default(false)
  dueDate     DateTime? @db.Date
  order       Int       @default(0) // position within the list
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

// Ecommerce meeting notes — shared across the department. Author edits/deletes
// their own; TL / Super Admin can manage any. meetingDate defaults to "today"
// (auto submission date); deadline is optional.
model MeetingNote {
  id           String      @id @default(cuid())
  authorId     String
  author       User        @relation("MeetingNoteAuthor", fields: [authorId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  title        String
  body         String
  meetingDate  DateTime    @db.Date
  deadline     DateTime?   @db.Date
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([departmentId, meetingDate])
}

// ---------- ITAD Bid Tracker ----------

enum BidType {
  RFQ
  RFP
  BID
  PO // Purchase Order
}

enum BidStatus {
  ACTIVE // Active Opportunity (default)
  SUBMITTED
  WON
  LOST
}

enum BidSubmissionType {
  PHYSICAL
  EMAIL
  PORTAL
}

/// An ITAD sales bid / opportunity. agentId is the submitting user; awardedPrice
/// is required once status = WON.
model Bid {
  id             String             @id @default(cuid())
  number         Int                @unique @default(autoincrement()) // human-facing bid_id
  title          String
  company        String
  type           BidType
  district       String?
  agentId        String
  agent          User               @relation("BidAgent", fields: [agentId], references: [id])
  departmentId   String? // the agent's department (ITAD) — scopes team-wide views
  department     Department?        @relation(fields: [departmentId], references: [id])
  status         BidStatus          @default(ACTIVE)
  dueDate        DateTime // date & time
  reminderSet    Boolean            @default(false)
  submissionType BidSubmissionType?
  priceQuoted    Float?
  awardedPrice   Float? // required when status = WON
  bidBond        Boolean            @default(false) // whether a bid bond applies
  bidBondAmount  Float? // optional bid bond value (only meaningful when bidBond)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([departmentId, status])
  @@index([agentId])
  @@index([dueDate])
}
