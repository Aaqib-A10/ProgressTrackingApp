{
  "name": "pulsetrack",
  "version": "0.1.0",
  "private": true,
  "description": "PulseTrack — internal progress tracking app (PERN, TypeScript)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w server && npm run build -w client",
    "test": "npm run test -w server",
    "prisma:generate": "npm run prisma:generate -w server",
    "prisma:migrate": "npm run prisma:migrate -w server",
    "prisma:studio": "npm run prisma:studio -w server",
    "fetch:media": "node scripts/fetch-pexels.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
